-xs font-black uppercase tracking-widest hover:bg-zinc-200 transition-all\"\n                                >\n                                    Cancel\n                                </button>\n                                <button\n                                    type=\"submit\"\n                                    disabled={submitting}\n                                    className=\"flex-1 py-3.5 rounded-2xl bg-indigo-500 text-white text-xs font-black uppercase tracking-widest hover:bg-indigo-600 shadow-lg shadow-indigo-500/20 active:scale-95 transition-all flex items-center justify-center gap-2\"\n                                >\n                                    {submitting ? <Loader2 className=\"w-4 h-4 animate-spin\" /> : (editingMapping ? 'Update Assignment' : 'Create Assignment')}\n                                </button>\n                            </div>\n                        </form>\n                    </div>\n                </div>\n            )}\n\n            {/* Confirm Box */}\n            <ConfirmBox\n                isOpen={deleteConfirmOpen}\n                loading={isDeleting}\n                title=\"Remove Assignment\"\n                description=\"Are you sure you want to remove this class-student assignment? This will unmap all students from this class for the selected year.\"\n                onConfirm={handleDelete}\n                onCancel={() => setDeleteConfirmOpen(false)}\n                confirmText=\"Remove\"\n                variant=\"danger\"\n            />\n        </div>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"/home/kamlesh/.gemini/antigravity/scratch/fastapi-app/frontend/src/app/(dashboard)/class-students/types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/home/kamlesh/.gemini/antigravity/scratch/fastapi-app/frontend/src/app/(dashboard)/class-students/utils.t